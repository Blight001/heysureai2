# HeySure AI 2.0 - Workspace Environment
# Copy this file to .env (in the workspace root) and fill in values.
# This .env is read by server/ (all four runtimes) and some launchers.

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL connection (required, only Postgres supported)
DATABASE_URL=postgresql+psycopg://heysure:heysure@127.0.0.1:5432/heysure

# Internal token used for /internal/* calls between gateway and the other three runtimes.
# Must be the same value in all four server processes.
HEYSURE_INTERNAL_TOKEN=heysure-dev-internal-token-change-me

# =============================================================================
# RUNTIME URLS (when running split processes)
# =============================================================================

MCP_RUNTIME_URL=http://127.0.0.1:3001
CONNECTOR_RUNTIME_URL=http://127.0.0.1:3002
AI_RUNTIME_URL=http://127.0.0.1:3003

# Use "remote" to have gateway dispatch chat work to ai-runtime (recommended for full setup)
AI_DISPATCH_MODE=remote

# Base URL used by web console and device clients to reach the API
SERVER_URL=http://127.0.0.1:3000

# Working directory for desktop/Android agents (where they store local files)
WORKSPACE_ROOT=

# =============================================================================
# EMBEDDING (knowledge base vector search)
# =============================================================================
# If you use a different provider for embeddings than for chat, set these.
# Example: use OpenAI embeddings while chatting with Grok/xAI.

HEYSURE_EMBEDDING_API_KEY=
HEYSURE_EMBEDDING_BASE_URL=
HEYSURE_EMBEDDING_MODEL=text-embedding-3-small
HEYSURE_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# AUTH
# =============================================================================

# JWT signing secret (change in production!)
JWT_SECRET=heysure-ai-secret-key-change-this-in-production

# Static agent token (used by desktop/browser/mobile agents when connecting via Socket.IO)
AGENT_TOKEN=

# =============================================================================
# THIRD PARTY
# =============================================================================

# Tavily web search (used by workspace.search tool)
TAVILY_API_KEY=

# ClawHub (skill registry)
CLAWHUB_REGISTRY_URL=https://clawhub.ai
CLAWHUB_API_TOKEN=

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
LOG_JSON=false

# =============================================================================
# OPTIONAL / ADVANCED
# =============================================================================

# HEYSURE_DB_AUTO_MIGRATE=0          # set to 0 when using the separate db-migrate service in Docker

# Public URLs (for link generation etc.)
# PUBLIC_BASE_URL=
# AGENT_SOCKET_URL=
