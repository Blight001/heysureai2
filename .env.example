# Copy to .env (or export in your shell) before running ``docker compose up``.

# Shared Bearer secret for inter-service /internal/* calls. Required when
# running the split-service deployment. Anything not empty works — choose a
# long random string for production.
HEYSURE_INTERNAL_TOKEN=heysure-dev-internal-token-change-me

# Optional: override the default Postgres credentials baked into compose.
# POSTGRES_USER=heysure
# POSTGRES_PASSWORD=heysure
# POSTGRES_DB=heysure
