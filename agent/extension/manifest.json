{
  "manifest_version": 3,
  "name": "浏览器 AI 助手",
  "description": "DOM-first AI browser control extension with semantic snapshots, guarded actions, and OpenAI-compatible chat APIs.",
  "version": "0.2.0",
  "icons": {
    "16": "extension/logo/icon16.png",
    "32": "extension/logo/icon32.png",
    "48": "extension/logo/icon48.png",
    "128": "extension/logo/icon128.png"
  },
  "action": {
    "default_title": "打开 AI 助手",
    "default_icon": {
      "16": "extension/logo/icon16.png",
      "32": "extension/logo/icon32.png",
      "48": "extension/logo/icon48.png",
      "128": "extension/logo/icon128.png"
    }
  },
  "background": {
    "service_worker": "extension/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "extension/content.js"
      ],
      "css": [
        "extension/panel.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
