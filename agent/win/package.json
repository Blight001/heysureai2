{
  "name": "heysure-agent-win",
  "version": "1.0.0",
  "description": "HeySure Agent - Windows Desktop Edition",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc",
    "start": "electron dist/main.js",
    "rebuild": "electron-rebuild -f -w robotjs",
    "package": "electron-builder --win"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5",
    "dotenv": "^16.4.5",
    "robotjs": "^0.6.0",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "@types/robotjs": "^0.6.3"
  },
  "build": {
    "appId": "com.heysure.agent.win",
    "productName": "HeySure Agent",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "assets/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
