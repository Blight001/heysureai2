# 后端地址（与 App 里填的"服务器地址"一致），如 http://192.168.1.10:3000
HEYSURE_SERVER_URL=http://127.0.0.1:3000

# 登录凭据（用于换取 token 与 agent socket 地址）。
HEYSURE_ACCOUNT=
HEYSURE_PASSWORD=

# 指定要控制的手机（adb devices 里的序列号）。留空则用唯一在线的那台。
ANDROID_SERIAL=

# 可选：自定义 adb 可执行文件路径（默认走 PATH 里的 adb）。
ADB_PATH=adb

# 可选：本端点的显示名（默认 android-adb-<serial>）。
HEYSURE_AGENT_NAME=
