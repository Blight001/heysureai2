<resources>

    <style name="CardTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="Field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">9dp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="BtnPrimary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnSecondary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnDanger" parent="BtnSecondary">
        <item name="android:textColor">@color/status_red</item>
    </style>

    <style name="BtnIcon">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:background">@drawable/pill_bg</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Hint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

</resources>
