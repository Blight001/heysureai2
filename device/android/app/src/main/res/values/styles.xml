<resources>

    <style name="CardTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="BtnPrimary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnSecondary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnDanger" parent="BtnSecondary">
        <item name="android:textColor">@color/status_red</item>
    </style>

    <style name="BtnIcon">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:background">@drawable/pill_bg</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Hint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

</resources>
