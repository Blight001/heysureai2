# HeySure Workspace (lightweight meta-repo)
# The three main components live in their own repositories:
#   - HeySure-Web     → web/
#   - HeySure-Server  → server/
#   - HeySure-Device  → device/
#
# These directories are populated by init-env.ps1 / init-env.sh
# and should NOT be committed into the workspace repo.

# Component directories (populated by bootstrap)
web/
server/
device/

# Environment
.env
.env.*
!.env.example

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Build / temp artifacts that may leak at workspace level
node_modules/
dist/
*.log
*.tmp

# Python (in case anything runs at root)
__pycache__/
*.pyc
.venv/
venv/
