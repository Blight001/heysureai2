# HeySure Workspace (lightweight meta-repo)
# The three main components are Git *submodules*:
#   - HeySure-Web     → web/
#   - HeySure-Server  → server/
#   - HeySure-Device  → device/
#
# They are linked via .gitmodules. Content lives in the separate repos.
# Use: git clone --recurse-submodules  or  git submodule update --init --recursive

# Environment
.env
.env.*
!.env.example

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Build / temp artifacts that may leak at workspace level
node_modules/
dist/
*.log
*.tmp

# Python (in case anything runs at root)
__pycache__/
*.pyc
.venv/
venv/
