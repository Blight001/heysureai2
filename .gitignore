# Browser extension build output
device/extension/dist/

# Android device (Gradle) build output
device/android/.gradle/
device/android/build/
device/android/app/build/
device/android/local.properties
device/android/HeySureAgent-*.apk
device/android/.idea/
device/android/captures/
device/android/*.iml
device/android/app/release/

# Build artifacts
*.out
*.exe
*.dll
*.so
*.dylib

# Databases and runtime data
*.db
*.sqlite
*.sqlite3
server/data/

# Temporary files
*.tmp
*.temp
*.bak


