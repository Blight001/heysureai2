# Device Python runtime venv (created per-machine by scripts/setup-python.js)
device/windows/device_runtime/python/.venv/
device/linux/device_runtime/python/.venv/
device/mac/device_runtime/python/.venv/
device/*/device_runtime/python/__pycache__/
